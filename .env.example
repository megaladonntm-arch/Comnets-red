# Railway usually provides DATABASE_URL automatically.
# If you want local startup to use the same database, paste the Railway value here.
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Used for JWT auth tokens.
SECRET_KEY=change-this-to-a-long-random-secret

# Public app URLs.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=https://comnot.netlify.app/

# Optional alternative to DATABASE_URL if you prefer separate PostgreSQL fields.
# PGHOST=host
# PGPORT=5432
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=password
